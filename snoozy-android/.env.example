# Clerk auth (publishable key — safe to expose)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your-clerk-publishable-key

# Backend API URL
EXPO_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# Stripe (publishable key — safe to expose, required when Stripe is active)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# Razorpay (key ID — safe to expose, required for Indian users when Razorpay is active)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your-key-id
