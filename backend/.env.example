PORT=3001

# Story generation (required)
OPENAI_API_KEY=sk-your-key-here

# Fish Audio TTS + voice cloning (required if any user selects a Fish Audio voice)
FISH_API_KEY=your-fish-audio-key
FISH_AUDIO_VOICE_ID=your-reference-id   # default voice model _id used as fallback

# ElevenLabs TTS (required if any user selects an ElevenLabs voice)
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here  # fallback if no voiceId sent by client

# Clerk auth
CLERK_SECRET_KEY=your-clerk-secret-key
