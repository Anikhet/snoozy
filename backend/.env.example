OPENAI_API_KEY=sk-your-key-here
PORT=3001

# TTS Provider: "openai" (default), "elevenlabs", "azure", or "fishaudio"
TTS_PROVIDER=azure

# OpenAI TTS voice: alloy, echo, fable, nova, onyx, shimmer
OPENAI_TTS_VOICE=shimmer

# ElevenLabs (only needed when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here

# Azure OpenAI (only needed when TTS_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://pushpankkatare09-8553-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-12-15
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts


# Fish Audio (only needed when TTS_PROVIDER=fishaudio)
FISH_API_KEY=your-fish-audio-key
FISH_AUDIO_VOICE_ID=your-reference-id   # public or private voice model _id (optional)

CLERK_SECRET_KEY=abc