OPENAI_API_KEY=sk-your-key-here
PORT=3001

# TTS Provider: "openai" (default) or "elevenlabs"
TTS_PROVIDER=azure

# OpenAI TTS voice: alloy, echo, fable, nova, onyx, shimmer
