PORT=3001

# Story generation (required)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI TTS voice: alloy, echo, fable, nova, onyx, shimmer
OPENAI_TTS_VOICE=shimmer

# Fish Audio TTS + voice cloning (required)
FISH_API_KEY=your-fish-audio-key
FISH_AUDIO_VOICE_ID=your-reference-voice-model-id

# ElevenLabs TTS (required if any user selects an ElevenLabs voice)
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id-here

# Clerk auth (backend secret key — NOT the publishable key)
CLERK_SECRET_KEY=your-clerk-secret-key
