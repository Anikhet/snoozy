PORT=3001

# Azure OpenAI — story generation (required)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_CHAT_VERSION=2025-01-01-preview
AZURE_OPENAI_TTS_DEPLOYMENT=tts-hd
AZURE_OPENAI_TTS_VERSION=2025-03-01-preview

# Fish Audio TTS + voice cloning (required)
FISH_API_KEY=your-fish-audio-key
FISH_AUDIO_VOICE_ID=your-reference-voice-model-id

# ElevenLabs TTS (required if any user selects an ElevenLabs voice)
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id-here

# Clerk auth (backend secret key — NOT the publishable key)
CLERK_SECRET_KEY=your-clerk-secret-key

# Stripe payments (required when payment integration is active)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key

# Razorpay payments (required for Indian users when payment integration is active)
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
